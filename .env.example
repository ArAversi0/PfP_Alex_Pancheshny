# Copy this file to .env and fill local-only secrets.
# .env is ignored by git and must not be committed.

# Must contain at least 32 bytes. Use a different value for every real environment.
PFP_JWT_SECRET=local-dev-secret-at-least-32-bytes-long

# Optional. If both values are empty, Google OAuth2 stays disabled.
PFP_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
PFP_GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Local web callback used after backend receives Google OAuth2 callback.
PFP_FRONTEND_BASE_URL=http://localhost:5173
PFP_OAUTH2_FRONTEND_CALLBACK_URL=http://localhost:5173/oauth2/callback